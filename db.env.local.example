# db.env.local.example — Template das credenciais do Postgres LOCAL (dev).
#
# Como usar:
#   cp db.env.local.example db.env.local
#   (ou rode ./setup-local.sh — já faz isso automaticamente)
#
# O arquivo db.env.local é gitignored (*.env.local). Edite à vontade,
# nunca vai pro git.
#
# Os valores abaixo batem com o que o docker-compose.yml expõe. Em geral
# não precisa mudar nada — só rode `docker compose up -d` e o Postgres já
# sobe com essas credenciais.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=gestao_servpen
DB_USER=gestao_servpen
DB_PASSWORD=dev_local_pwd
