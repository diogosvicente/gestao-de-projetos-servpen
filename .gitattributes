# Normaliza line endings: arquivos de texto sempre LF (Unix), mesmo quando
# editados no Windows via SMB. Bash em Linux quebra se um script .sh chegar
# com CRLF (`set -euo pipefail\r` vira "invalid option name").
#
# Aplica em todos os arquivos que casarem (na ordem das regras abaixo).

* text=auto eol=lf

# Scripts e configs do servidor — OBRIGATÓRIO LF
*.sh         text eol=lf
*.bash       text eol=lf
*.service    text eol=lf
*.conf       text eol=lf
*.env        text eol=lf
*.env.example text eol=lf

# Código-fonte
*.py         text eol=lf
*.toml       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.json       text eol=lf

# Documentação
*.md         text eol=lf
*.txt        text eol=lf
*.rst        text eol=lf

# Binários — não tocar
*.db         binary
*.sqlite     binary
*.sqlite3    binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.pdf        binary
*.xlsx       binary
*.xls        binary
*.zip        binary
*.tar        binary
*.gz         binary
*.woff       binary
*.woff2      binary
*.ttf        binary
*.otf        binary
